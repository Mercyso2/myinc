# Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLE_A_SERVICE_ROLE_KEY_AQUI
MEDIA_BUCKET=creative-media

# OpenAI imagem
OPENAI_API_KEY=sk-...
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_SIZE_FEED=1024x1536
OPENAI_IMAGE_SIZE_STORY=1024x1536
OPENAI_IMAGE_SIZE_SQUARE=1024x1024
OPENAI_IMAGE_SIZE_FACEBOOK=1536x1024
OPENAI_IMAGE_MAX_PROMPT_CHARS=8000

# Worker
WORKER_ID=myinc-worker-01
POLL_INTERVAL_MS=4000
JOB_IDLE_SLEEP_MS=5000
JOB_RETRY_BASE_SECONDS=45

# Vídeo real: conecte qualquer provedor externo que aceite POST e retorne video_url/url
# ou retorne job_id/status_url para polling. Sem isso, o worker gera capa/storyboard e deixa aviso.
VIDEO_PROVIDER_API_URL=
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_STATUS_URL=
VIDEO_PROVIDER_TIMEOUT_MINUTES=35
VIDEO_PROVIDER_POLL_SECONDS=20
VIDEO_DURATION_SECONDS=8
VIDEO_ASPECT_RATIO=9:16
