# MYINC Social Media AI — produção em hospedagem/VPS
VITE_SUPABASE_URL=same-origin
VITE_SUPABASE_ANON_KEY=local-myinc-anon-key
VITE_APP_URL=https://SEU-DOMINIO.com.br
VITE_APP_ENV=production
VITE_DEMO_MODE=false
VITE_APP_MODE=local

APP_MODE=local
APP_ENV=production
NODE_ENV=production
LOCAL_API_HOST=0.0.0.0
LOCAL_API_PORT=8787
APP_PORT=8787
LOCAL_AUTH_REQUIRED=true
LOCAL_API_KEY=TROQUE_ESSA_CHAVE_LONGA
CORS_ALLOW_ORIGIN=https://SEU-DOMINIO.com.br
DATABASE_DRIVER=sqlite
SQLITE_PATH=myinc.sqlite
DATA_DIR=data

LOCAL_ADMIN_EMAIL=rodrigocarvalhosantos@hotmail.com
LOCAL_ADMIN_PASSWORD=TROQUE_ESSA_SENHA_FORTE
LOCAL_ADMIN_NAME=Rodrigo Carvalho Santos

OPENAI_API_KEY=COLE_SUA_CHAVE_OPENAI_AQUI
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_FALLBACK_MODELS=gpt-image-1.5,gpt-image-1
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_FORMAT=png
AI_STRICT_MODE=true
MOCK_AI_PROVIDER=false
MOCK_META_PROVIDER=false

# Vídeo IA real via OpenAI Videos/Sora
ENABLE_OPENAI_VIDEO=true
OPENAI_VIDEO_MODEL=sora-2-pro
OPENAI_VIDEO_SIZE=1080x1920
OPENAI_VIDEO_SECONDS=12
OPENAI_VIDEO_POLL_TIMEOUT_SECONDS=360
OPENAI_VIDEO_POLL_INTERVAL_SECONDS=15

# Recomendado para mídia pública HTTPS usada pela Meta
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=myinc-social-media-ai

META_GRAPH_VERSION=v23.0
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ID=
META_PAGE_ACCESS_TOKEN=

PUBLIC_MEDIA_BASE_URL=https://res.cloudinary.com/SEU_CLOUD_NAME/image/upload/myinc-social-media-ai
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_PUBLICATION_MODE=semi-automatic
MAX_POSTS_PER_DAY=6

ENABLE_LOCAL_FFMPEG_VIDEO=false
FFMPEG_PATH=ffmpeg
LOCAL_VIDEO_DURATION_SECONDS=8
ALLOW_LOCAL_PUBLISH_SIMULATION=false
