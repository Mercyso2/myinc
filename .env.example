# FRONTEND PÚBLICO — Vercel Project Settings
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=COLE_SUA_ANON_KEY
VITE_APP_ENV=production
VITE_APP_URL=https://SEU-APP.vercel.app

# ISOLAMENTO COM O MESMO BANCO
# Use o brand_id do ambiente que este deploy pode enxergar/processar.
# Se deixar errado, o app pode listar/processar dados de outro ambiente.
VITE_DEFAULT_BRAND_ID=00000000-0000-0000-0000-000000000001

# BACKEND VERCEL API — nunca expor no browser
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COLE_SUA_SERVICE_ROLE
CRON_SECRET=gere-uma-chave-forte-com-32-caracteres
VERCEL_APP_URL=https://SEU-APP.vercel.app
WORKER_BRAND_ID=00000000-0000-0000-0000-000000000001
DEFAULT_BRAND_ID=00000000-0000-0000-0000-000000000001
ISOLATED_ENVIRONMENT_NAME=myinc-vercel-isolado

# Runtime pelo Painel ADM / runtime_secrets
# OPENAI_API_KEY
# OPENAI_TEXT_MODEL=gpt-4.1
# OPENAI_IMAGE_MODEL=gpt-image-1
# MEDIA_BUCKET=creative-media
# PUBLIC_MEDIA_BASE_URL=https://SEU-PROJETO.supabase.co/storage/v1/object/public/creative-media
# META_PAGE_ACCESS_TOKEN=
# META_PAGE_ID=
# META_INSTAGRAM_BUSINESS_ID=
# OPENAI_VIDEO_ENDPOINT=opcional
