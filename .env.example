# Frontend público (Vite) — permitido no navegador
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=anon-public-key
VITE_APP_URL=https://seudominio.com.br
VITE_APP_ENV=production
VITE_DEMO_MODE=false
MOCK_AI_PROVIDER=false
MOCK_META_PROVIDER=false
CORS_ALLOW_ORIGIN=https://seudominio.com.br

# Backend / Supabase Edge Functions — nunca usar VITE_
SUPABASE_SERVICE_ROLE_KEY=service-role-key
OPENAI_API_KEY=COLE_SUA_CHAVE_OPENAI_AQUI
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_FALLBACK_MODELS=gpt-image-1,gpt-image-1-mini
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_FORMAT=png
ENABLE_OPENAI_VIDEO=true
OPENAI_VIDEO_MODEL=sora-2-pro
OPENAI_VIDEO_SIZE=1080x1920
OPENAI_VIDEO_SECONDS=12
OPENAI_VIDEO_POLL_TIMEOUT_SECONDS=360
OPENAI_VIDEO_POLL_INTERVAL_SECONDS=12
META_GRAPH_VERSION=v23.0
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ID=
META_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
PUBLIC_MEDIA_BASE_URL=https://seu-projeto.supabase.co/storage/v1/object/public/creative-media
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_PUBLICATION_MODE=semi-automatic
MAX_POSTS_PER_DAY=6
DEMO_MODE=false
ALLOW_LOCAL_PUBLISH_SIMULATION=false
