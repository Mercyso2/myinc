{
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "NITRO_PRESET=vercel npm run build",
  "functions": {
    "api/worker/process.js": {
      "maxDuration": 60
    },
    "api/jobs/process-next.js": {
      "maxDuration": 60
    },
    "api/jobs/retry.js": {
      "maxDuration": 10
    },
    "api/debug/health.js": {
      "maxDuration": 10
    },
    "api/edge/process-next.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/worker/process",
      "schedule": "0 9 * * *"
    }
  ]
}
